# API runtime
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_PORT=8000
NGINX_PORT=8080
APP_CORS_ORIGINS=http://localhost:19006,http://localhost:8081

# Database / queue
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/tusbina
DB_SCHEMA_MODE=create_all
REDIS_URL=redis://localhost:6379/0
WORKER_POLL_INTERVAL_SEC=5
DEMO_MONTHLY_QUOTA_SEC=3600
PREMIUM_MONTHLY_QUOTA_SEC=36000

# Supabase Auth
# When SUPABASE_URL is set and ENABLE_AUTH is not explicitly "false",
# authentication is enabled automatically.  Set ENABLE_AUTH=false to
# force local-dev mode with the x-user-id header fallback.
ENABLE_AUTH=false
DEFAULT_USER_ID=demo-user
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_JWT_AUDIENCE=authenticated

# Storage backend
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=data/uploads
PUBLIC_UPLOAD_BASE_URL=http://localhost:8000/static/uploads
UPLOAD_ALLOWED_EXTENSIONS=pdf
UPLOAD_MAX_FILES=5
UPLOAD_MAX_FILE_SIZE_MB=25
UPLOAD_VALIDATE_PDF_SIGNATURE=true

# Cloudflare R2 (if STORAGE_BACKEND=r2)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY=your-access-key
R2_SECRET_KEY=your-secret-key
R2_BUCKET=tusbina-audio
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://cdn.yourdomain.com

# LLM + TTS
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_TIMEOUT_SEC=45
SCRIPT_SOURCE_MAX_CHARS=12000
SCRIPT_TARGET_MAX_CHARS=1200
GENERATION_MAX_PARTS=50
TTS_PROVIDER=piper
TTS_FALLBACK_TO_DUMMY=true
TTS_MAX_CHARS_PER_PART=1000
TTS_MODELS_DIR=data/models
PIPER_BINARY_PATH=piper
PIPER_USE_CUDA=false
PIPER_MODEL_PATH=
PIPER_MODEL_CONFIG_PATH=
PIPER_MODEL_URL=https://huggingface.co/rhasspy/piper-voices/resolve/main/tr/tr_TR/dfki/medium/tr_TR-dfki-medium.onnx
PIPER_MODEL_CONFIG_URL=https://huggingface.co/rhasspy/piper-voices/resolve/main/tr/tr_TR/dfki/medium/tr_TR-dfki-medium.onnx.json
PIPER_LENGTH_SCALE=1.12
PIPER_NOISE_SCALE=0.60
PIPER_NOISE_W_SCALE=0.75
PIPER_SENTENCE_SILENCE=0.18
PIPER_VOLUME=1.0
PIPER_NO_NORMALIZE=false
PIPER_VOICE_ARDA_LENGTH_SCALE=1.08
PIPER_VOICE_SELIN_LENGTH_SCALE=1.16
