{
  "name": "tusbina",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/mobile",
    "packages/shared"
  ],
  "scripts": {
    "mobile:start": "npm run start --workspace @tusbina/mobile --",
    "mobile:android": "npm run android --workspace @tusbina/mobile",
    "mobile:ios": "npm run ios --workspace @tusbina/mobile",
    "mobile:web": "npm run web --workspace @tusbina/mobile",
    "mobile:prebuild:ios": "npm run prebuild:ios --workspace @tusbina/mobile",
    "mobile:devbuild:ios:sim": "npm run devbuild:ios:sim --workspace @tusbina/mobile",
    "mobile:devbuild:ios:device": "npm run devbuild:ios:device --workspace @tusbina/mobile",
    "mobile:typecheck": "npm run typecheck --workspace @tusbina/mobile",
    "mobile:lint": "npm run lint --workspace @tusbina/mobile",
    "api:dev": "cd apps/api && uvicorn app.main:app --reload",
    "api:worker": "cd apps/api && python -m app.worker",
    "api:test": "cd apps/api && pytest -q",
    "api:lint": "cd apps/api && ruff check .",
    "api:format": "cd apps/api && ruff format .",
    "check": "npm run mobile:typecheck && npm run api:test"
  },
  "dependencies": {
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.10",
    "expo-crypto": "~15.0.8",
    "expo-web-browser": "~15.0.10"
  }
}
